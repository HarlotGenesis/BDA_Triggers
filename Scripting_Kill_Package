  {
      if (!gwc.userdata.kills.plan)
      {
          gwc.output.append("not killing");
          return;
      }
      
      var k = gwc.userdata.kills;
      
      if (k.check) 
      {
          k.check.paths[k.check.paths.length] = k.check.last.concat(k.plan[k.step].path);
          k.check.last = [];
      }
  
       k.got += 1;
       
      if (k.got >= k.per_room) 
      {
          gwc.connection.send("k_next", true);
          return;
      }
      gwc.connection.send("k_start", true);
  }
    
  setTimeout(killer, 100);

