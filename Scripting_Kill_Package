  // Ensure userdata structure exists
  gwc.userdata.laststep = gwc.userdata.laststep || {};
  var laststep = gwc.userdata.laststep;
  
  if (laststep.plan && laststep.step !== undefined) {
    // Resume the saved plan
    gwc.userdata.kills = { 
      plan: laststep.plan, 
      step: laststep.step + 1, // Increment step to avoid repetition
      got: 0 
    };
  
    // Check if we've already completed the plan
    if (gwc.userdata.kills.step >= gwc.userdata.kills.plan.length) {
      gwc.output.append("No more steps to resume. Plan is complete.");
      return;
    }
  
    gwc.output.append("Resuming from step " + gwc.userdata.kills.step + "...");
    
    // Send the next commands
    for (var i = 0; i < gwc.userdata.kills.plan[gwc.userdata.kills.step].path.length; i += 1) {
      gwc.connection.send(gwc.userdata.kills.plan[gwc.userdata.kills.step].path[i]);
    }
    gwc.connection.send("k_start", true);
  } else {
    gwc.output.append("No saved progress found. Start a plan first.");
  }
  

